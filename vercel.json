{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/for/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/games/packing", "destination": "/games/packing/index.html" }
  ]
}
